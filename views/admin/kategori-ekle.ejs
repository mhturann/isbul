<!DOCTYPE html>
<html lang="tr">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/index.css">
    <link rel="stylesheet" href="/css/main.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet">
</head>

<body>
    <%- include("../partials/navbar") %>

        <main class="admin-konteyner" style="max-width: 600px; margin: 50px auto; padding: 20px;">
            <div class="kategori-form-kutu">

                <div class="form-baslik">
                    <h2>Yeni Kategori Ekle</h2>
                    <p>Sisteme yeni bir hizmet kategorisi tanımlayın.</p>
                </div>

                <form action="/admin/kategori-ekle" method="POST">
                    <div class="form-grup">
                        <label for="kategori_adi">Kategori Adı</label>
                        <input type="text" id="kategori_adi" name="kategori_adi"
                            placeholder="Kategori Adı" required autocomplete="off">
                    </div>

                    <button type="submit" class="kaydet-buton">
                        Kategoriyi Kaydet
                    </button>
                </form>

            </div>
        </main>

        <%- include("../partials/footer") %>
</body>

</html>