<!DOCTYPE html>
<html lang="tr">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/index.css">
    <link rel="stylesheet" href="/css/main.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>

<body>
    <%- include("../partials/navbar") %>

    <main class="profil-konteyner">
        <div class="profil-baslik-alani">
            <h1>Profilim</h1>
        </div>

        <div class="profil-grid-sistemi">

            <div style="background: white; border-radius: 16px; padding: 40px; text-align: center; box-shadow: 0 10px 30px rgba(0,0,0,0.03); border: 1px solid #f1f5f9; margin-bottom: 30px; grid-column: 1 / -1;">
                
                <div style="position: relative; width: 120px; height: 120px; margin: 0 auto 20px auto;">
                    
                    <div style="width: 100%; height: 100%; background: #e0f2fe; color: #0369a1; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 3.5rem; overflow: hidden; border: 3px solid #fff; box-shadow: 0 4px 10px rgba(0,0,0,0.08);">
                        <% if (locals.user && locals.user.profil_fotografi) { %>
                            <img src="/uploads/<%= locals.user.profil_fotografi %>" alt="Profil Fotoğrafı" style="width: 100%; height: 100%; object-fit: cover;">
                        <% } else { %>
                            <i class="bi bi-person-fill"></i>
                        <% } %>
                    </div>

                    <% if (locals.user && locals.user.profil_fotografi) { %>
                        <button type="button" title="Fotoğrafı Sil" onclick="document.getElementById('fotoSilModal').style.display='flex';" style="position: absolute; bottom: 0; left: -5px; background: #ef4444; color: white; border: none; width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; box-shadow: 0 2px 5px rgba(0,0,0,0.2); transition: background 0.2s;" onmouseover="this.style.background='#dc2626'" onmouseout="this.style.background='#ef4444'">
                            <i class="bi bi-trash3-fill" style="font-size: 1rem;"></i>
                        </button>

                        <div id="fotoSilModal" style="display: none; position: fixed; z-index: 1000; left: 0; top: 0; width: 100%; height: 100%; background-color: rgba(0,0,0,0.6); align-items: center; justify-content: center; backdrop-filter: blur(2px);">
                            <div style="background: white; padding: 30px; border-radius: 12px; width: 90%; max-width: 400px; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25); text-align: center;">
                                <i class="bi bi-exclamation-circle" style="font-size: 3.5rem; color: #ef4444;"></i>
                                <h2 style="margin: 15px 0 10px 0; color: #1f2937; font-size: 1.4rem;">Fotoğrafı Sil</h2>
                                <p style="color: #4b5563; margin-bottom: 25px; font-size: 1rem;">Profil fotoğrafınızı kalıcı olarak silmek istediğinize emin misiniz?</p>
                                
                                <div style="display: flex; gap: 10px; justify-content: center;">
                                    <button type="button" onclick="document.getElementById('fotoSilModal').style.display='none';" style="background: #f3f4f6; color: #4b5563; border: 1px solid #d1d5db; padding: 8px 16px; border-radius: 6px; font-weight: 600; cursor: pointer; font-size: 0.9rem; transition: background 0.2s;">
                                        Vazgeç
                                    </button>
                                    <form action="/profil-fotograf-sil" method="POST" style="margin: 0;">
                                        <button type="submit" class="reddet-buton" style="background: #ef4444; color: white; border: none; padding: 8px 16px; border-radius: 6px; font-weight: 600; cursor: pointer; font-size: 0.9rem; transition: background 0.2s;" onmouseover="this.style.background='#dc2626'" onmouseout="this.style.background='#ef4444'">
                                            Evet, Sil
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    <% } %>

                    <form id="avatarForm" action="/profil-fotograf-guncelle" method="POST" enctype="multipart/form-data" style="position: absolute; bottom: 0; right: -5px;">
                        <input type="file" id="avatarInput" name="avatar" accept="image/*" style="display: none;" onclick="this.value=null;">
                        <button type="button" id="kalemButon" title="Fotoğraf Yükle/Değiştir" style="background: #3b82f6; color: white; border: none; width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; box-shadow: 0 2px 5px rgba(0,0,0,0.2); transition: background 0.2s;" onmouseover="this.style.background='#2563eb'" onmouseout="this.style.background='#3b82f6'">
                            <i class="bi bi-pencil-fill" style="font-size: 1rem;"></i>
                        </button>
                    </form>

                </div>

                <h1 style="color: #0f172a; margin: 0 0 10px 0; font-size: 2rem;">
                    <%= locals.user ? locals.user.ad : '' %> <%= locals.user ? locals.user.soyad : '' %>
                </h1>

                <div style="margin-top: 20px; color: #64748b; font-size: 0.95rem;">
                    <i class="bi bi-calendar-check"></i> Katılım: <%= (locals.user && locals.user.kayitTarihi) ? new Date(locals.user.kayitTarihi).toLocaleDateString('tr-TR') : 'Bilinmiyor' %>
                </div>
            </div>


            <div class="sol-sutun">
                
                <div class="panel-baslik">
                    <h3 style="margin: 0; color: #1f2937;">Gelen Teklifler</h3>
                </div>
            
                <% const aktifIlanlar = typeof ilanlarim !== 'undefined' ? ilanlarim.filter(ilan => ilan.durum !== 4) : []; %>

                <% if (aktifIlanlar.length > 0) { %>
                    <div class="ilanlar-listesi">
                        <% aktifIlanlar.forEach(ilan => { %>
                            
                            <div class="benim-ilanim-kart">
                                <div class="ilan-ust-bilgi">
                                    <div>
                                        <h2 style="margin: 0 0 5px 0; color: #1f2937; font-size: 1.3rem;">
                                            <%= ilan.baslik %>
                                        </h2>
                                        <span class="durum-etiketi <%= ilan.durum == 1 ? 'aktif' : 'beklemede' %>">
                                            <%= ilan.durum == 1 ? 'Aktif' : 'İşlemde' %>
                                        </span>
                                    </div>
                                </div>

                                <div class="teklifler-alani">
                                    <h4 style="margin: 20px 0 10px 0; border-bottom: 1px solid #eee; padding-bottom: 5px; font-size: 1rem;">
                                        Gelen Teklifler
                                    </h4>

                                    <% const teklifListesi = ilan.tekliflers || ilan.teklifler || []; %>

                                    <% if (teklifListesi.length > 0) { %>
                                        <div class="teklif-kutulari">
                                            <% teklifListesi.forEach(teklif => { %>
                                                <div class="teklif-satiri">
                                                    <div class="teklif-detay">
                                                        <strong>Fiyat: <span style="color: #10b981;"><%= teklif.teklif_fiyati %> ₺</span></strong>
                                                        <p style="margin: 5px 0 0 0; color: #555; font-size: 0.9rem;">
                                                            "<%= teklif.mesaj %>"
                                                        </p>
                                                    </div>

                                                    <div class="teklif-aksiyon">
                                                        <% if (teklif.durum === 'Bekliyor') { %>
                                                            <form action="/teklif-kabul/<%= teklif.id %>" method="POST" class="onay-formu" style="display: inline-block;">
                                                                <button type="submit" class="kabul-et-buton">Kabul Et</button>
                                                            </form>

                                                            <form action="/teklif-reddet/<%= teklif.id %>" method="POST" class="onay-formu" style="display: inline-block;">
                                                                <button type="submit" class="reddet-buton">Reddet</button>
                                                            </form>

                                                        <% } else if (teklif.durum === 'Kabul Edildi') { %>
                                                            <div style="display: flex; gap: 10px; align-items: center; flex-wrap: wrap;">
                                                                <span style="background: #10b981; color: white; padding: 6px 12px; border-radius: 6px; font-size: 0.85rem; font-weight: bold;">
                                                                    Kabul Edildi
                                                                </span>
                                                                
                                                                <a href="/mesajlar/<%= ilan.id %>" style="background: #1f2937; color: white; padding: 6px 12px; border-radius: 6px; font-size: 0.85rem; font-weight: bold; text-decoration: none;">
                                                                    Mesajlaş
                                                                </a>
                                                                
                                                                <button type="button"
                                                                        onclick="document.getElementById('degerlendirme-modal-<%= ilan.id %>').style.display='flex';"
                                                                        style="background: #f98e15; color: white; border: none; padding: 6px 12px; border-radius: 6px; font-weight: bold; cursor: pointer; font-size: 0.85rem; transition: background 0.2s;">
                                                                    Değerlendir ve Bitir
                                                                </button>
                                                            </div>

                                                            <div id="degerlendirme-modal-<%= ilan.id %>" style="display: none; position: fixed; z-index: 1000; left: 0; top: 0; width: 100%; height: 100%; background-color: rgba(0,0,0,0.6); align-items: center; justify-content: center; backdrop-filter: blur(2px);">
                                                                <div style="background: white; padding: 30px; border-radius: 12px; width: 90%; max-width: 500px; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25); position: relative;">
                                                                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px;">
                                                                        <h2 style="margin: 0; color: #1f2937; font-size: 1.4rem;">Değerlendir</h2>
                                                                        <span onclick="document.getElementById('degerlendirme-modal-<%= ilan.id %>').style.display='none';" style="cursor: pointer; font-size: 1.8rem; color: #9ca3af; line-height: 1; transition: color 0.2s;" onmouseover="this.style.color='#ef4444'" onmouseout="this.style.color='#9ca3af'">&times;</span>
                                                                    </div>

                                                                    <form action="/degerlendir/<%= ilan.id %>" method="POST" style="display: flex; flex-direction: column; gap: 20px;">
                                                                        <div>
                                                                            <label style="display: block; font-size: 0.95rem; font-weight: bold; color: #374151; margin-bottom: 8px;">Puanınız</label>
                                                                            <div class="yildiz-puanlama">
                                                                                <input type="radio" id="yildiz5-<%= ilan.id %>" name="puan" value="5" checked />
                                                                                <label for="yildiz5-<%= ilan.id %>" title="5 Yıldız - Mükemmel"><i class="bi bi-star-fill"></i></label>

                                                                                <input type="radio" id="yildiz4-<%= ilan.id %>" name="puan" value="4" />
                                                                                <label for="yildiz4-<%= ilan.id %>" title="4 Yıldız - İyi"><i class="bi bi-star-fill"></i></label>

                                                                                <input type="radio" id="yildiz3-<%= ilan.id %>" name="puan" value="3" />
                                                                                <label for="yildiz3-<%= ilan.id %>" title="3 Yıldız - Ortalama"><i class="bi bi-star-fill"></i></label>

                                                                                <input type="radio" id="yildiz2-<%= ilan.id %>" name="puan" value="2" />
                                                                                <label for="yildiz2-<%= ilan.id %>" title="2 Yıldız - Kötü"><i class="bi bi-star-fill"></i></label>

                                                                                <input type="radio" id="yildiz1-<%= ilan.id %>" name="puan" value="1" />
                                                                                <label for="yildiz1-<%= ilan.id %>" title="1 Yıldız - Berbat"><i class="bi bi-star-fill"></i></label>
                                                                            </div>
                                                                        </div>

                                                                        <div>
                                                                            <label style="display: block; font-size: 0.95rem; font-weight: bold; color: #374151; margin-bottom: 8px;">Yorumunuz</label>
                                                                            <textarea name="yorum" rows="4" placeholder="Düşüncelerinizi paylaşın..." style="width: 100%; padding: 12px; border-radius: 8px; border: 1px solid #d1d5db; outline: none; resize: none; font-family: inherit; font-size: 1rem; background: #f9fafb; box-sizing: border-box;" required></textarea>
                                                                        </div>

                                                                        <div style="display: flex; gap: 15px; margin-top: 10px;">
                                                                            <button type="button" onclick="document.getElementById('degerlendirme-modal-<%= ilan.id %>').style.display='none';" style="flex: 1; background: #f3f4f6; color: #4b5563; border: 1px solid #d1d5db; padding: 12px; border-radius: 8px; font-weight: bold; cursor: pointer; font-size: 1rem; transition: background 0.2s;">
                                                                                Vazgeç
                                                                            </button>
                                                                            <button type="submit" style="flex: 2; background: #f59e0b; color: white; border: none; padding: 12px; border-radius: 8px; font-weight: bold; cursor: pointer; font-size: 1rem; transition: background 0.2s;">
                                                                                Değerlendir ve Bitir
                                                                            </button>
                                                                        </div>
                                                                    </form>
                                                                </div>
                                                            </div>
                                                        <% } else if (teklif.durum === 'Reddedildi') { %>
                                                            <span style="background: #ef4444; color: white; padding: 6px 12px; border-radius: 6px; font-size: 0.85rem; font-weight: bold;">
                                                                Reddedildi
                                                            </span>
                                                        <% } %>
                                                    </div>
                                                </div>
                                            <% }) %>
                                        </div>
                                    <% } else { %>
                                        <p style="color: #9ca3af; font-style: italic; font-size: 0.9rem;">Henüz teklif gelmemiş.</p>
                                    <% } %>
                                </div>
                            </div>
                            
                        <% }) %>
                    </div>
                <% } else { %>
                    <div class="bos-durum">
                        <p style="font-size: 1.1rem; color: #64748b; margin: 0;">Henüz gelen teklif yok.</p>
                    </div>
                <% } %>


                <div class="panel-baslik" style="margin-top: 40px;">
                    <h3 style="margin: 0; color: #1f2937;">Kazandığım İşler</h3>
                </div>

                <% if (typeof kazandigimIsler !== 'undefined' && kazandigimIsler.length > 0) { %>
                    <div class="ilanlar-listesi">
                        <% kazandigimIsler.forEach(is => { %>
                            <% 
                                const ilanBilgisi = is.ilanlar || {};
                                const musteriBilgisi = ilanBilgisi.user || ilanBilgisi.User || {};
                            %>
                            <div class="benim-ilanim-kart" style="border-left: 5px solid #3b82f6;">
                                <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                                    <div>
                                        <h2 style="margin: 0 0 5px 0; color: #1f2937; font-size: 1.2rem;">
                                            <%= ilanBilgisi.baslik || 'İlan Bulunamadı' %>
                                        </h2>
                                        <p style="margin: 0; color: #6b7280; font-size: 0.9rem;">
                                            Müşteri: <strong>
                                                <%= musteriBilgisi.ad || 'Bilinmeyen' %> <%= musteriBilgisi.soyad || 'Müşteri' %>
                                            </strong>
                                        </p>
                                    </div>
                                    <span style="background: #eff6ff; color: #1e3a8a; padding: 4px 10px; border-radius: 20px; font-size: 0.8rem; font-weight: bold;">
                                        İş Alındı
                                    </span>
                                </div>

                                <div style="margin-top: 15px; background: #f8fafc; padding: 12px; border-radius: 8px; display: flex; justify-content: space-between; align-items: center;">
                                    <p style="margin: 0; color: #475569; font-size: 0.95rem;">
                                        Verilen Teklif: <strong><%= is.teklif_fiyati %> ₺</strong>
                                    </p>
                                    <a href="/mesajlar/<%= is.ilan_id %>" style="background: #3b82f6; color: white; padding: 8px 15px; border-radius: 6px; text-decoration: none; font-weight: bold; font-size: 0.9rem;">
                                        Müşteriyle Mesajlaş
                                    </a>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                <% } else { %>
                    <div class="bos-durum">
                        <p style="font-size: 1rem; color: #64748b; margin: 0;">Henüz kazandığınız bir iş bulunmuyor.</p>
                    </div>
                <% } %>
            </div>

            <div class="sag-sutun">
                <div class="panel-baslik">
                    <h3 style="margin: 0; color: #1f2937;">Müşteri Değerlendirmeleri</h3>
                </div>

                <div class="degerlendirme-kutu">
                    <div style="text-align: center; margin-bottom: 25px; padding-bottom: 20px; border-bottom: 1px solid #f1f5f9;">
                        
                        <% const ortPuanNum = parseFloat(ortalamaPuan || 0); %>

                        <% if (ortPuanNum >= 4) { %>
                         <h1 style="margin: 0; color: #00ff99; font-size: 3.5rem;">
                            <%= ortalamaPuan %>
                        </h1>
                        <% } else if (ortPuanNum >= 3 && ortPuanNum < 4) { %>
                         <h1 style="margin: 0; color: #f59e0b; font-size: 3.5rem;">
                            <%= ortalamaPuan %>
                        </h1>
                        <% } else { %>
                         <h1 style="margin: 0; color: #ef4444; font-size: 3.5rem;">
                            <%= ortalamaPuan %>
                        </h1>
                        <% } %>

                        <p style="color: #6b7280; font-size: 0.9rem; margin-top: 5px;">Toplam <strong>
                                <%= typeof yorumlarDetayli !== 'undefined' ? yorumlarDetayli.length : 0 %>
                            </strong> değerlendirme
                        </p>
                    </div>

                    <div class="yorumlar-listesi">
                        <% if (typeof yorumlarDetayli !== 'undefined' && yorumlarDetayli.length > 0) { %>
                            <% yorumlarDetayli.forEach(yorum => { %>
                                <div style="background: #f8fafc; padding: 15px; border-radius: 8px; margin-bottom: 15px; border-left: 4px solid #f59e0b;">
                                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
                                        <strong style="color: #1f2937; font-size: 0.9rem;">
                                            <%= yorum.musteriAdSoyad %>
                                        </strong>
                                        <span style="font-size: 0.8rem;">
                                            <%= '⭐'.repeat(yorum.puan) %>
                                        </span>
                                    </div>
                                    <p style="margin: 0; color: #475569; font-size: 0.9rem; line-height: 1.4;">
                                        "<%= yorum.yorum %>"
                                    </p>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <div class="bos-yorum">
                                <p style="margin: 0; color: #9ca3af; font-size: 0.9rem; text-align: center;">
                                    Henüz değerlendirme almadınız.
                                </p>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>

        </div>
    </main>

    <%- include("../partials/footer") %>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const kalemButon = document.getElementById('kalemButon');
            const avatarInput = document.getElementById('avatarInput');
            const avatarForm = document.getElementById('avatarForm');

            if (kalemButon && avatarInput && avatarForm) {
                kalemButon.addEventListener('click', function() {
                    avatarInput.click(); 
                });

                avatarInput.addEventListener('change', function() {
                    if(this.files && this.files.length > 0) {
                        avatarForm.submit(); 
                    }
                });
            }
        });
    </script>
</body>

</html>