<!DOCTYPE html>
<html lang="tr">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/index.css">
    <link rel="stylesheet" href="/css/main.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>

<body>
    <%- include("../partials/navbar") %>

        <main class="detay-konteyner">

            <div
                style="background: white; border-radius: 16px; padding: 40px; text-align: center; box-shadow: 0 10px 30px rgba(0,0,0,0.03); border: 1px solid #f1f5f9; margin-bottom: 30px;">
                
                <div
                    style="width: 100px; height: 100px; background: #e0f2fe; color: #0369a1; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 3rem; margin: 0 auto 20px auto; overflow: hidden;">
                    <% if (profilSahibi.profil_fotografi) { %>
                        <img src="/uploads/<%= profilSahibi.profil_fotografi %>" alt="Profil Fotoğrafı" style="width: 100%; height: 100%; object-fit: cover;">
                    <% } else { %>
                        <i class="bi bi-person-fill"></i>
                    <% } %>
                </div>

                <h1 style="color: #0f172a; margin: 0 0 10px 0; font-size: 2rem;">
                    <%= profilSahibi.ad %>
                        <%= profilSahibi.soyad %>
                </h1>


                <div style="margin-top: 20px; color: #64748b; font-size: 0.95rem;">
                    <i class="bi bi-calendar-check"></i> Katılım: <%= profilSahibi.kayitTarihi ?
                        profilSahibi.kayitTarihi.toLocaleDateString('tr-TR') : 'Bilinmiyor' %>
                </div>
            </div>

            <div class="detay-kart">
                <div class="ilan-icerik">
                    <h3
                        style="margin-top: 0; color: #0f172a; border-bottom: 2px solid #f1f5f9; padding-bottom: 15px; display: flex; align-items: center; gap: 10px;">
                        Aktif İlanları (<%= ilanlar.length %>)
                    </h3>

                    <% if (ilanlar && ilanlar.length> 0) { %>
                        <div style="display: flex; flex-direction: column; gap: 15px; margin-top: 20px;">
                            <% ilanlar.forEach(ilan=> { %>
                                <a href="/ilan/<%= ilan.id %>" style="text-decoration: none; color: inherit;">
                                    <div style="padding: 20px; border: 1px solid #e2e8f0; border-radius: 12px; transition: all 0.2s; background: #f8fafc;"
                                        onmouseover="this.style.borderColor='#3b82f6'; this.style.background='white';"
                                        onmouseout="this.style.borderColor='#e2e8f0'; this.style.background='#f8fafc';">
                                        <h4 style="margin: 0 0 10px 0; color: #1e293b; font-size: 1.1rem;">
                                            <%= ilan.baslik %>
                                        </h4>
                                        <span
                                            style="font-size: 0.85rem; color: #64748b; background: #e2e8f0; padding: 4px 10px; border-radius: 6px;">
                                            <%= ilan.kategori ? ilan.kategori.kategori_adi : 'Genel' %>
                                        </span>
                                    </div>
                                </a>
                                <% }) %>
                        </div>
                        <% } else { %>
                            <div style="text-align: center; padding: 40px 0; color: #94a3b8;">
                                <i class="bi bi-inbox"
                                    style="font-size: 3rem; margin-bottom: 15px; display: block;"></i>
                                <p>Kullanıcının şu an aktif bir ilanı bulunmuyor.</p>
                            </div>
                            <% } %>
                </div>

                <div class="ilan-sidebar">
                    
                    <h3
                        style="margin-top: 0; color: #0f172a; border-bottom: 2px solid #f1f5f9; padding-bottom: 15px; display: flex; align-items: center; justify-content: space-between;">
                        <span style="display: flex; align-items: center; gap: 10px;">
                            Değerlendirmeler
                        </span>
                        <span style="font-size: 0.9rem; background: #fffbeb; color: #d97706; padding: 4px 12px; border-radius: 20px; border: 1px solid #fde68a;">
                            <i class="bi bi-star-fill" style="margin-right: 2px;"></i> <%= typeof ortalamaPuan !== 'undefined' ? ortalamaPuan : '0.0' %>
                        </span>
                    </h3>

                    <% if (degerlendirmeler && degerlendirmeler.length> 0) { %>
                        <div style="display: flex; flex-direction: column; gap: 15px; margin-top: 15px;">
                            <% degerlendirmeler.forEach(degerlendirme=> { %>

                                <% const yorumYapan=degerlendirme.user
                                    || {}; %>

                                    <div
                                        style="background: #f8fafc; padding: 15px; border-radius: 8px; border: 1px solid #e2e8f0;">
                                        <div
                                            style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
                                            <strong style="color: #1e293b; font-size: 0.95rem;">
                                                <%= yorumYapan.ad || 'İsimsiz' %>
                                                    <%= yorumYapan.soyad || '' %>
                                            </strong>
                                        </div>

                                        <% if (degerlendirme.puan) { %>
                                            <div style="color: #f59e0b; font-size: 0.85rem; margin-bottom: 8px;">
                                                <% for(let i=0; i<5; i++) { %>
                                                    <i
                                                        class="bi <%= i < degerlendirme.puan ? 'bi-star-fill' : 'bi-star' %>"></i>
                                                    <% } %>
                                            </div>
                                            <% } %>

                                                <p
                                                    style="margin: 0; color: #475569; font-size: 0.9rem; line-height: 1.5;">
                                                   <i> "<%= degerlendirme.yorum ||  '' %>"</i>
                                                </p>
                                    </div>

                                <% }) %>
                        </div>

                        <% } else { %>
                            <div
                                style="text-align: center; padding: 30px 0; color: #94a3b8; background: #f8fafc; border-radius: 12px; border: 1px dashed #cbd5e1; margin-top: 20px;">
                                <i class="bi bi-stars"
                                    style="font-size: 2.5rem; margin-bottom: 10px; display: block; color: #cbd5e1;"></i>
                                <p style="margin: 0; font-size: 0.95rem;">Henüz bir değerlendirme almamış.</p>
                            </div>
                            <% } %>
                </div>
            </div>

        </main>

        <%- include("../partials/footer") %>
</body>

</html>