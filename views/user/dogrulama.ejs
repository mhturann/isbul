<!DOCTYPE html>
<html lang="tr">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/index.css">
    <link rel="stylesheet" href="/css/main.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet">

</head>
<%- include("../partials/navbar") %>

    <body>

        <main class="auth-konteyner">
            <div class="auth-kart">
                <div class="auth-baslik">
                    <h1>Hesabınızı Doğrulayın</h1>
                    <p>E-posta adresinize gönderdiğimiz 6 haneli kodu aşağıya girin.</p>
                </div>

                <% if (typeof hata !=='undefined' && hata) { %>
                    <div class="hata-mesaji">
                        <%= hata %>
                    </div>
                    <% } %>

                        <form action="/dogrulama" method="POST" class="auth-form">
                            <input type="hidden" name="email" value="<%= email %>">

                            <div class="form-grup">
                                <label for="kod">Doğrulama Kodu</label>
                                <input type="text" id="kod" name="kod" placeholder="123456" maxlength="6" required>
                            </div>

                            <button type="submit" class="incele-buton tam-genislik">Doğrula</button>
                        </form>
                        <div class="auth-alt-bilgi">
                            <p>Kodu almadınız mı? <a href="/yeniden-gonder?email=<%= email %>">Yeniden Gönder</a></p>
                        </div>
            </div>
        </main>

        <%- include("../partials/footer") %>
    </body>

</html>