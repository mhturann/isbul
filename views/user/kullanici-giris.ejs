<!DOCTYPE html>
<html lang="tr">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/index.css">
    <link rel="stylesheet" href="/css/main.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet">

</head>
<%- include("../partials/navbar") %>

    <body>

        <main class="auth-konteyner">
            <div class="auth-kart">
                <div class="auth-baslik">
                    <h1>Hoş Geldin</h1>
                    <p>Devam etmek için hesabına giriş yap.</p>
                </div>

                <% if (typeof hata !=='undefined' && hata) { %>
                    <div class="hata-mesaji">
                        <%= hata %>
                    </div>
                    <% } %>

                        <form action="/giris" method="POST" class="auth-form">
                            <div class="form-grup">
                                <label for="email">E-posta Adresi</label>
                                <input type="email" id="email" name="email" placeholder="Email" required>
                            </div>

                            <div class="form-grup">
                                <label for="sifre">Şifre</label>
                                <input type="password" id="sifre" name="sifre" placeholder="••••••••" required>
                            </div>
                            <br>

                            <button type="submit" class="incele-buton tam-genislik">Giriş Yap</button>
                        </form>

                        <div class="auth-alt-bilgi">
                            <p>Henüz hesabın yok mu? <a href="/kayit">Hemen Kayıt Ol</a></p>
                        </div>
            </div>
        </main>

        <%- include("../partials/footer") %>
    </body>

</html>